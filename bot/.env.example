# Tezbozor bot — copy to .env. NEVER commit .env.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Backend API base URL (includes /api). Used from Phase 4 for notifications.
API_BASE_URL=http://localhost:3000/api

# Public HTTPS URL of the Mini App (a tunnel/ngrok URL in dev, real domain in
# prod). Telegram only accepts https for WebApp buttons. Leave empty in early
# dev — the bot will greet without the button.
MINIAPP_URL=

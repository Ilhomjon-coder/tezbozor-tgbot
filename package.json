{
  "name": "tezbozor-tgbot",
  "version": "0.0.1",
  "description": "Tezbozor customer surface — grammY bot + Telegram Mini App",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "gen:api": "orval --config orval.config.ts",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:bot": "pnpm --filter @tezbozor/bot dev",
    "dev:miniapp": "pnpm --filter @tezbozor/miniapp dev"
  },
  "devDependencies": {
    "orval": "^7.5.0",
    "typescript": "^5.7.2"
  }
}
